VITE_API_BASE_URL=http://localhost:8080/api/v1
## Default test key (matches backend seed)
# Free user key:
VITE_API_KEY=sk_test_free_123456
# Other seeded keys you can use:
# Standard: sk_test_standard_123456
# Pro:      sk_test_pro_123456
VITE_GOOGLE_MAPS_KEY=your_google_maps_key_here
VITE_STRIPE_KEY=your_stripe_key_here
